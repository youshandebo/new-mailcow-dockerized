<div class="tab-pane fade" id="tab-config-ai" role="tabpanel">
  <div class="card mb-4">
    <div class="card-header d-flex align-items-center">
      <i class="bi bi-robot me-2"></i> AI 邮件助手设置
    </div>
    <div class="card-body">
      <div id="ai-settings-alert"></div>
      <form id="ai-settings-form" method="post">
        <div class="row mb-3">
          <label class="col-sm-3 col-form-label">AI 服务商</label>
          <div class="col-sm-9">
            <select class="form-select" id="ai-provider" name="provider">
              <option value="openai">OpenAI 兼容（中转站）</option>
              <option value="claude">Claude (Anthropic)</option>
            </select>
            <small class="form-text text-muted">选择你的 AI 服务类型，大多数中转站使用 OpenAI 兼容格式</small>
          </div>
        </div>

        <div class="row mb-3" id="ai-url-group">
          <label class="col-sm-3 col-form-label">API 地址</label>
          <div class="col-sm-9">
            <input type="url" class="form-control" id="ai-api-url" name="baseUrl" placeholder="https://api.example.com/v1">
            <small class="form-text text-muted">OpenAI 兼容格式的 API 基础地址（如 https://api.openai.com/v1）</small>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label">API Key</label>
          <div class="col-sm-9">
            <input type="password" class="form-control" id="ai-api-key" name="apiKey" placeholder="sk-xxxxxx">
            <small class="form-text text-muted" id="ai-key-preview"></small>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label">模型名称</label>
          <div class="col-sm-9">
            <input type="text" class="form-control" id="ai-model" name="model" placeholder="gpt-4o">
            <small class="form-text text-muted">例如：gpt-4o、gpt-3.5-turbo、claude-3-sonnet-20240229</small>
          </div>
        </div>

        <div class="row mb-3">
          <label class="col-sm-3 col-form-label">Temperature</label>
          <div class="col-sm-9">
            <input type="number" class="form-control" id="ai-temperature" name="temperature" placeholder="0.7" step="0.1" min="0" max="2" value="0.7">
            <small class="form-text text-muted">控制输出的随机性，0=确定性，2=最随机</small>
          </div>
        </div>

        <hr>
        <div class="row mb-3">
          <div class="col-sm-9 offset-sm-3">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg"></i> 保存设置
            </button>
            <button type="button" class="btn btn-secondary ms-2" id="ai-test-btn">
              <i class="bi bi-lightning"></i> 测试连接
            </button>
          </div>
        </div>
      </form>

      <div id="ai-test-result" class="mt-3" style="display:none;"></div>
    </div>
  </div>
</div>

<script>
$(document).ready(function() {
  // Load current AI settings
  $.get('/api/ai-settings.php', function(data) {
    if (data) {
      $('#ai-provider').val(data.provider || 'openai').trigger('change');
      $('#ai-api-url').val(data.baseUrl || data.apiUrl || '');
      $('#ai-model').val(data.model || '');
      $('#ai-temperature').val(data.temperature || 0.7);
      if (data.apiKeyPreview) {
        $('#ai-key-preview').text('当前密钥: ' + data.apiKeyPreview);
      }
    }
  });

  // Save settings
  $('#ai-settings-form').on('submit', function(e) {
    e.preventDefault();
    var settings = {
      provider: $('#ai-provider').val(),
      baseUrl: $('#ai-api-url').val(),
      apiKey: $('#ai-api-key').val(),
      model: $('#ai-model').val(),
      temperature: parseFloat($('#ai-temperature').val()) || 0.7
    };
    // Don't send empty apiKey (preserve existing)
    if (!settings.apiKey) delete settings.apiKey;

    $.ajax({
      type: 'POST',
      url: '/api/ai-settings.php',
      data: JSON.stringify(settings),
      contentType: 'application/json',
      dataType: 'json',
      success: function(data) {
        if (data && data.success) {
          $('#ai-settings-alert').html('<div class="alert alert-success">' + (data.message || '保存成功') + '</div>');
          // Refresh key preview
          $.get('/api/ai-settings.php', function(d) {
            if (d && d.apiKeyPreview) $('#ai-key-preview').text('当前密钥: ' + d.apiKeyPreview);
          });
        } else {
          $('#ai-settings-alert').html('<div class="alert alert-danger">' + (data.error || '保存失败') + '</div>');
        }
        setTimeout(function() { $('#ai-settings-alert').html(''); }, 3000);
      },
      error: function(xhr) {
        var msg = '请求失败';
        try { msg = JSON.parse(xhr.responseText).error || msg; } catch(e) {}
        $('#ai-settings-alert').html('<div class="alert alert-danger">' + msg + '</div>');
      }
    });
  });

  // Test connection
  $('#ai-test-btn').on('click', function() {
    var btn = $(this);
    btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> 测试中...');
    $('#ai-test-result').hide();

    $.ajax({
      type: 'POST',
      url: '/api/ai-test.php',
      data: JSON.stringify({}),
      contentType: 'application/json',
      dataType: 'json',
      success: function(data) {
        $('#ai-test-result').show();
        if (data && data.success) {
          $('#ai-test-result').html('<div class="alert alert-success">' + (data.message || '连接成功！') + '</div>');
        } else {
          $('#ai-test-result').html('<div class="alert alert-danger">连接失败：' + (data.error || '未知错误') + '</div>');
        }
      },
      error: function() {
        $('#ai-test-result').show().html('<div class="alert alert-danger">测试请求失败</div>');
      },
      complete: function() {
        btn.prop('disabled', false).html('<i class="bi bi-lightning"></i> 测试连接');
      }
    });
  });

  // Show/hide URL field based on provider
  $('#ai-provider').on('change', function() {
    if ($(this).val() === 'claude') {
      $('#ai-url-group').hide();
    } else {
      $('#ai-url-group').show();
    }
  }).trigger('change');
});
</script>
