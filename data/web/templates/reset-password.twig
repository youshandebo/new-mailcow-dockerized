{% extends 'base.twig' %}

{% block body_class %}login-page{% endblock %}
{% block navbar %}{% endblock %}

{% block content %}
<div class="login-banner" style="height:300px">
  <div class="dark-mode-switch form-check form-switch">
    <label class="form-check-label"><i class="bi bi-moon-fill"></i></label>
    <input class="form-check-input ms-1" type="checkbox" id="dark-mode-toggle">
  </div>
  <div class="brand-area">
    <img src="{{ logo|default('/img/cow_mailcow.svg') }}" alt="mailcow" style="height:48px;margin-bottom:10px;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.15))">
    <h1>{{ ui_texts.main_name|default('Mailcow Webmail') }}</h1>
  </div>
</div>

<div class="login-card-wrapper">
  <div class="login-card" style="max-width:440px">
    <div class="login-card-header">
      <h2><i class="bi bi-key-fill me-2"></i>{{ lang.login.reset_password }}</h2>
    </div>
    <div class="login-card-body">
      {% if is_reset_token_valid %}
      <form method="post" autofill="off">
        <input type="hidden" name="token" value="{{ reset_token }}" />
        <div class="qq-form-group">
          <i class="bi bi-lock-fill input-icon"></i>
          <input type="password" name="new_password" placeholder="{{ lang.login.new_password }}" required="" autofocus="" autocomplete="new-password">
        </div>
        <div class="qq-form-group">
          <i class="bi bi-lock-fill input-icon"></i>
          <input type="password" name="new_password2" placeholder="{{ lang.login.new_password_confirm }}" required="" autocomplete="new-password">
        </div>
        <small id="mismatch_alert" class="text-danger d-none">{{ lang.login.password_mismatch }}</small>
        <button type="submit" class="btn-qq-login mt-3" name="pw_reset">{{ lang.login.reset_password }}</button>
      </form>
      {% elseif reset_token is null %}
      <form method="post" autofill="off">
        <div class="qq-form-group">
          <i class="bi bi-person-fill input-icon"></i>
          <input type="text" name="username" placeholder="{{ lang.login.username }}" required="" autofocus="" autocomplete="username">
        </div>
        <button type="submit" class="btn-qq-login mt-3" name="pw_reset_request">{{ lang.login.request_reset_password }}</button>
      </form>
      {% else %}
      <p class="text-center" style="color:#595959">{{ lang.login.invalid_pass_reset_token|raw }}</p>
      <div class="text-center mt-3">
        <a href="/" style="color:#4A90D9;text-decoration:none">{{ lang.login.back_to_mailcow }}</a>
      </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
