{% extends 'base.twig' %}

{% block body_class %}login-page{% endblock %}
{% block navbar %}{% endblock %}

{% block content %}
<div class="login-banner">
  <div class="dark-mode-switch form-check form-switch">
    <label class="form-check-label"><i class="bi bi-moon-fill"></i></label>
    <input class="form-check-input ms-1" type="checkbox" id="dark-mode-toggle">
  </div>
  {% if not oauth2_request %}
  <div class="lang-selector dropdown">
    <button type="button" {% if available_languages|length == 1 %}disabled="true"{% endif %} class="btn dropdown-toggle" data-bs-toggle="dropdown">
      <span class="flag-icon flag-icon-{{ mailcow_locale[-2:] }}"></span>
    </button>
    <ul class="dropdown-menu">
      {% for key, val in available_languages %}
        <li>
          <a class="dropdown-item {% if mailcow_locale == key %}active{% endif %}" href="?{{ query_string({'lang': key}) }}">
            <span class="flag-icon flag-icon-{{ key[-2:] }}"></span>{{ val }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  <div class="brand-area">
    <img src="{{ logo|default('/img/cow_mailcow.svg') }}" alt="mailcow" style="height:52px;margin-bottom:12px;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.15))">
    <h1>{{ ui_texts.main_name|default('Mailcow Webmail') }}</h1>
    <p>{{ ui_texts.title_name|default('Secure & Modern Email') }}</p>
  </div>
</div>

<div class="login-card-wrapper">
  <div class="login-card">
    <div class="login-card-header">
      <h2>{% if oauth2_request %}{{ lang.oauth2.authorize_app }}{% else %}{{ lang.login.login_user }}{% endif %}</h2>
    </div>
    <div class="login-card-body">
      {% if ui_texts.ui_announcement_text and ui_texts.ui_announcement_active %}
      <div class="login-announcement alert alert-{{ ui_texts.ui_announcement_type }}">{{ ui_texts.ui_announcement_text }}</div>
      {% endif %}

      {% if is_mobileconfig %}
      <div class="alert alert-info" style="font-size:13px;">{{ lang.login.mobileconfig_info }}</div>
      {% endif %}

      {% if custom_login.force_sso != 1 %}
      <form method="post" autofill="off">
        <div class="qq-form-group">
          <i class="bi bi-person-fill input-icon"></i>
          <input name="login_user" autocorrect="off" autocapitalize="none" type="{% if is_mobileconfig %}email{% else %}text{% endif %}" id="login_user" placeholder="{{ lang.login.email }}" required="" autofocus="" autocomplete="username">
        </div>
        <div class="qq-form-group">
          <i class="bi bi-lock-fill input-icon"></i>
          <input name="pass_user" type="password" id="pass_user" placeholder="{{ lang.login.password }}" required="" autocomplete="current-password">
        </div>
        <div class="forgot-link">
          <a href="/reset-password">{{ lang.login.forgot_password }}</a>
        </div>
        <button type="submit" class="btn-qq-login" value="Login">{{ lang.login.login }}</button>
      </form>
      <div class="login-divider"><span>{{ lang.login.other_logins }}</span></div>
      {% endif %}

      <div>
        {% if has_iam_sso %}
        <a class="btn-other-login" href="/?iam_sso=1"><i class="bi bi-cloud-arrow-up-fill"></i> {{ lang.admin.iam_sso }}</a>
        {% endif %}
        {% if custom_login.force_sso != 1 %}
        <a class="btn-other-login" href="#" id="fido2-login"><i class="bi bi-shield-fill-check"></i> {{ lang.login.fido2_webauthn }}</a>
        {% endif %}
      </div>

      {% if login_delay %}
      <div class="delay-alert alert alert-info">{{ lang.login.delayed|format(login_delay) }}</div>
      {% endif %}
      <div id="fido2-alerts"></div>

      {% if not oauth2_request and (mailcow_apps or app_links) and not hide_mailcow_apps %}
      <div class="apps-section">
        {% for app in mailcow_apps %}
          {% if not app.hide %}
            {% if not skip_sogo or not is_uri('SOGo', app.link) %}
            <a href="{{ app.link }}" class="app-link" {% if app.description %}title="{{ app.description }}"{% endif %}>{{ app.name }}</a>
            {% endif %}
          {% endif %}
        {% endfor %}
        {% for row in app_links %}
          {% for key, val in row %}
          {% if not val.hide %}
            <a href="{{ val.link }}" class="app-link">{{ key }}</a>
          {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% if custom_login.hide_admin_quicklink != 1 or custom_login.hide_domainadmin_quicklink != 1 %}
<div class="login-footer-links">
  {{ lang.login.login_linkstext }}
  {% if custom_login.hide_admin_quicklink != 1 %}<a href="/admin">{{ lang.login.login_admintext }}</a>{% endif %}
  {% if custom_login.hide_admin_quicklink != 1 and custom_login.hide_domainadmin_quicklink != 1 %}|{% endif %}
  {% if custom_login.hide_domainadmin_quicklink != 1 %}<a href="/domainadmin">{{ lang.login.login_domainadmintext }}</a>{% endif %}
</div>
{% endif %}

{% if not oauth2_request and ui_texts.help_text %}
<div class="help-card mt-4">
  <div class="card-header">
    <a class="btn btn-link p-0" data-bs-toggle="collapse" href="#collapse1"><i class="bi bi-patch-question-fill"></i> {{ lang.start.help }}</a>
  </div>
  <div id="collapse1" class="card-collapse collapse">
    <div class="card-body">
      <p>{{ ui_texts.help_text }}</p>
    </div>
  </div>
</div>
{% endif %}
{% endblock %}
