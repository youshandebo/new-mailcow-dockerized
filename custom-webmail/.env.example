# Server
NODE_ENV=development
PORT=3001

# IMAP (Dovecot)
IMAP_HOST=dovecot-mailcow
IMAP_PORT=993
IMAP_TLS=true

# SMTP (Postfix)
SMTP_HOST=postfix-mailcow
SMTP_PORT=587
SMTP_TLS=true

# Mailcow Admin API
MAILCOW_API_URL=http://nginx-mailcow
MAILCOW_API_KEY=your-api-key-here

# Redis (reuses mailcow's Redis)
REDIS_URL=redis://:your-redis-pass@redis-mailcow:6379

# Claude AI (defaults, can be changed in admin panel at /settings)
CLAUDE_API_KEY=sk-ant-your-key-here

# Auth
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=24h
